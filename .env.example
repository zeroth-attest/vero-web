# Server
PORT=8080
NODE_ENV=development
# BASE_URL is only needed as a fallback — in production, callback URLs are
# derived automatically from the request hostname (e.g. voice.vero.technology).
# For local dev, leave this as localhost:
BASE_URL=http://localhost:8080

# Google OAuth (Sign In with Google)
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# LinkedIn OAuth (Sign In with LinkedIn using OpenID Connect)
# Create at: https://www.linkedin.com/developers/apps
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# GitHub OAuth
# Create at: https://github.com/settings/developers -> OAuth Apps
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Microsoft Entra ID / Azure AD (Sign In with Microsoft)
# Create at: https://portal.azure.com -> App registrations
# Use "common" tenant for personal + work accounts
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Facebook Login
# Create at: https://developers.facebook.com/apps
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# Apple Sign In
# Create at: https://developer.apple.com -> Certificates, Identifiers & Profiles
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
# Paste the contents of the .p8 private key file (with \n for newlines)
APPLE_PRIVATE_KEY=
